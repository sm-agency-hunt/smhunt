# SMHUNT Production Environment Configuration
# Copy this file to .env and fill in your actual values

# Application Settings
APP_NAME=SMHUNT
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database_name
DATABASE_POOL_SIZE=20
DATABASE_POOL_OVERFLOW=10
DATABASE_ECHO=False

# Redis Configuration (for caching and Celery broker)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_SERIALIZER=pickle
CELERY_ACCEPT_CONTENT=['pickle', 'json']
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC

# Secret Keys and Security
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration
EMAIL_BACKEND=smtp
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=notifications@yourdomain.com

# AI Provider API Keys
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key

# Data Enrichment API Keys
CLEARBIT_API_KEY=your-clearbit-api-key
HUNTER_IO_API_KEY=your-hunter-io-api-key
EMAIL_VERIFIER_API_KEY=your-email-verifier-api-key

# Professional Search and Social Media APIs
LINKEDIN_API_KEY=your-linkedin-api-key
TWITTER_API_KEY=your-twitter-api-key
SALESNAVL_API_KEY=your-salesnavl-api-key

# SMS/Messaging Services
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Cloud Storage
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# Analytics and Monitoring
SENTRY_DSN=your-sentry-dsn
GA_TRACKING_ID=your-google-analytics-id
POSTHOG_API_KEY=your-posthog-api-key

# Payment Processing
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Frontend Configuration
FRONTEND_URL=https://yourdomain.com
BACKEND_CORS_ORIGINS=["https://yourdomain.com", "http://localhost:3000"]

# Task Worker Configuration
WORKER_CONCURRENCY=4
WORKER_PREFETCH_MULTIPLIER=1
TASK_ACKS_LATE=True
WORKER_MAX_TASKS_PER_CHILD=1000

# Rate Limiting
RATE_LIMIT_DEFAULT=100/hour
RATE_LIMIT_DISCOVERY=50/hour
RATE_LIMIT_ENRICHMENT=30/hour
RATE_LIMIT_EMAIL=20/hour

# Retry Configuration
TASK_RETRY_ATTEMPTS=3
TASK_RETRY_DELAY=60
MAX_RETRY_DELAY=300

# Timeout Configuration
REQUEST_TIMEOUT=30
DATABASE_TIMEOUT=30
EXTERNAL_API_TIMEOUT=60

# Feature Flags
ENABLE_MOCK_PROVIDERS=false
ENABLE_ASYNC_WORKERS=true
ENABLE_RATE_LIMITING=true
ENABLE_ANALYTICS=true
ENABLE_EMAIL_AUTOMATION=true
ENABLE_SCHEDULING=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_PAYMENT_PROCESSING=true

# Third-party Integration Keys
ZOOM_API_KEY=your-zoom-api-key
ZOOM_API_SECRET=your-zoom-api-secret
SLACK_BOT_TOKEN=your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
NOTION_API_KEY=your-notion-api-key
AIRTABLE_API_KEY=your-airtable-api-key

# Compliance and Legal
PRIVACY_POLICY_URL=https://yourdomain.com/privacy
TERMS_OF_SERVICE_URL=https://yourdomain.com/terms